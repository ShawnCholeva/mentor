#!/usr/bin/env bash
# Stop hook — interaction logger for coaching system
# Part of mentor plugin (v3.1)
#
# Fires after every Claude response. Reads session state written by
# user-prompt-submit, counts turns from the transcript, and appends a
# structured entry to ~/.claude/coaching/interactions.jsonl.
# Every 5th interaction, triggers an async user model update.
# Always exits 0 — never disrupts Claude Code's normal shutdown flow.

set -euo pipefail

# Skip if this is an internal mentor call (prevents recursive logging)
[[ -n "${MENTOR_INTERNAL:-}" ]] && exit 0

COACHING_DIR="${HOME}/.claude/coaching"
LOG_FILE="${COACHING_DIR}/interactions.jsonl"
USER_MODEL_FILE="${COACHING_DIR}/user-model.json"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
UPDATE_SCRIPT="${SCRIPT_DIR}/lib/update-user-model.sh"

mkdir -p "$COACHING_DIR"

# ─── Resolve jq (auto-installs on first use) ──────────────────────────────────
# shellcheck source=lib/bootstrap-jq.sh
source "${SCRIPT_DIR}/lib/bootstrap-jq.sh" || exit 0

# ─── Read stdin ───────────────────────────────────────────────────────────────
INPUT=$(cat)

SESSION_ID=$(    echo "$INPUT" | "$JQ" -r '.session_id     // ""' 2>/dev/null || echo "")
TRANSCRIPT_PATH=$(echo "$INPUT" | "$JQ" -r '.transcript_path // ""' 2>/dev/null || echo "")

[[ -z "$SESSION_ID" ]] && exit 0

# ─── Read session state from user-prompt-submit hook ─────────────────────────
STATE_FILE="${COACHING_DIR}/session-${SESSION_ID}.tmp"
COACHING_TRIGGERED="false"
INTERVENTION_TYPE="null"
COACHING_MESSAGE=""
FRICTION=""
SKILL_AVAILABLE="false"

if [[ -f "$STATE_FILE" ]]; then
    STATE=$(cat "$STATE_FILE")
    COACHING_TRIGGERED=$(echo "$STATE" | "$JQ" -r 'if .coaching_triggered then "true" else "false" end' 2>/dev/null || echo "false")
    INTERVENTION_TYPE=$(echo "$STATE" | "$JQ" -r 'if .type then ("\"" + .type + "\"") else "null" end'  2>/dev/null || echo "null")
    COACHING_MESSAGE=$( echo "$STATE" | "$JQ" -r '.message // ""'                                       2>/dev/null || echo "")
    FRICTION=$(         echo "$STATE" | "$JQ" -r '.friction // ""'                                      2>/dev/null || echo "")
    SKILL_AVAILABLE=$(  echo "$STATE" | "$JQ" -r 'if .skill_available then "true" else "false" end'      2>/dev/null || echo "false")
fi

# ─── Count user turns from transcript ────────────────────────────────────────
TURN_COUNT=1
if [[ -n "$TRANSCRIPT_PATH" ]] && [[ -f "$TRANSCRIPT_PATH" ]]; then
    TURN_COUNT=$(grep -c '"role":"user"\|"role": "user"' "$TRANSCRIPT_PATH" 2>/dev/null || echo "1")
    [[ "$TURN_COUNT" -lt 1 ]] && TURN_COUNT=1
fi

# ─── Estimate session outcome from transcript ──────────────────────────────
SESSION_OUTCOME="unknown"
if [[ -n "$TRANSCRIPT_PATH" ]] && [[ -f "$TRANSCRIPT_PATH" ]]; then
    if grep -q '"git commit"\|"git add"' "$TRANSCRIPT_PATH" 2>/dev/null; then
        SESSION_OUTCOME="achieved"
    elif tail -c 5000 "$TRANSCRIPT_PATH" 2>/dev/null | grep -qiE '"error"|"fail"|traceback' 2>/dev/null; then
        SESSION_OUTCOME="not_achieved"
    fi
fi

# ─── Classify intent from transcript ─────────────────────────────────────────
INTENT="unknown"
SKILL_USED="null"
LAST_PROMPT=""

if [[ -n "$TRANSCRIPT_PATH" ]] && [[ -f "$TRANSCRIPT_PATH" ]]; then
    LAST_PROMPT=$(grep '"role":"user"\|"role": "user"' "$TRANSCRIPT_PATH" 2>/dev/null | \
        tail -1 | \
        "$JQ" -r '
            (.message.content // .content) |
            if type == "array" then [.[].text? // ""] | join(" ")
            else (. // "" | tostring)
            end' 2>/dev/null | head -c 500 || echo "")
fi

if [[ -n "$LAST_PROMPT" ]]; then
    if echo "$LAST_PROMPT" | grep -qE "^/[a-z]"; then
        _skill=$(echo "$LAST_PROMPT" | grep -oE "^/[a-z][a-z0-9:-]+" | head -1)
        SKILL_USED="\"${_skill}\""
        INTENT="skill-invoked"
    else
        WORD_COUNT=$(echo "$LAST_PROMPT" | wc -w | tr -d '[:space:]')
        if [[ "$WORD_COUNT" -lt 6 ]]; then
            INTENT="vague"
        else
            INTENT="direct"
        fi
    fi
fi

# ─── Generate entry ID ────────────────────────────────────────────────────────
TIMESTAMP=$(date +%s)
ENTRY_ID=$(uuidgen 2>/dev/null || \
           cat /proc/sys/kernel/random/uuid 2>/dev/null || \
           printf '%s-%s' "$SESSION_ID" "$TIMESTAMP")

# ─── Append log entry (jq builds valid JSON, no manual escaping) ─────────────
# Truncate prompt for log entry
PROMPT_SUMMARY="${LAST_PROMPT:0:200}"

FRICTION_TYPE="null"
[[ -n "$FRICTION" ]] && FRICTION_TYPE="\"${FRICTION}\""

"$JQ" -n -c \
    --arg     id                "$ENTRY_ID" \
    --arg     session_id        "$SESSION_ID" \
    --argjson timestamp         "$TIMESTAMP" \
    --arg     intent            "$INTENT" \
    --argjson skill_used        "$SKILL_USED" \
    --argjson turn_count        "$TURN_COUNT" \
    --arg     prompt_summary    "$PROMPT_SUMMARY" \
    --argjson coaching_triggered "$COACHING_TRIGGERED" \
    --argjson intervention_type "$INTERVENTION_TYPE" \
    --argjson friction_type     "$FRICTION_TYPE" \
    --argjson skill_available   "$SKILL_AVAILABLE" \
    --arg     session_outcome   "$SESSION_OUTCOME" \
    '{
        id:                 $id,
        session_id:         $session_id,
        timestamp:          $timestamp,
        intent:             $intent,
        skill_used:         $skill_used,
        turn_count:         $turn_count,
        prompt_summary:     $prompt_summary,
        coaching_triggered: $coaching_triggered,
        intervention_type:  $intervention_type,
        friction_type:      $friction_type,
        skill_available:    $skill_available,
        session_outcome:    $session_outcome
    }' >> "$LOG_FILE" 2>/dev/null || true

# ─── Trigger user model update every 5th interaction ─────────────────────────
if [[ -f "$UPDATE_SCRIPT" ]]; then
    INTERACTION_COUNT=$(wc -l < "$LOG_FILE" 2>/dev/null | tr -d '[:space:]' || echo "0")
    if (( INTERACTION_COUNT % 5 == 0 )); then
        USER_MODEL="{}"
        [[ -f "$USER_MODEL_FILE" ]] && USER_MODEL=$(cat "$USER_MODEL_FILE" 2>/dev/null || echo "{}")

        # jq -s (slurp) reads all JSONL lines into a single JSON array
        RECENT_INTERACTIONS=$(tail -20 "$LOG_FILE" 2>/dev/null | "$JQ" -s '.' 2>/dev/null || echo "[]")

        SESSION_COACHING="{}"
        if [[ "$COACHING_TRIGGERED" == "true" ]] && [[ "$INTERVENTION_TYPE" != "null" ]]; then
            SESSION_COACHING=$("$JQ" -n \
                --argjson type    "$INTERVENTION_TYPE" \
                --arg     message "$COACHING_MESSAGE" \
                '{type: $type, message: $message}' 2>/dev/null || echo "{}")
        fi

        UPDATE_PAYLOAD=$("$JQ" -n \
            --argjson user_model          "$USER_MODEL" \
            --argjson recent_interactions "$RECENT_INTERACTIONS" \
            --argjson session_coaching    "$SESSION_COACHING" \
            '{user_model: $user_model, recent_interactions: $recent_interactions, session_coaching: $session_coaching}' \
            2>/dev/null) || true

        [[ -n "$UPDATE_PAYLOAD" ]] && printf '%s' "$UPDATE_PAYLOAD" | bash "$UPDATE_SCRIPT" &
    fi
fi

exit 0
