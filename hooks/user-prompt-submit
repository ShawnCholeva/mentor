#!/usr/bin/env bash
# UserPromptSubmit hook вЂ” AI-powered prompt coaching via additionalContext
# Part of mentor plugin (v3.1)
#
# Evaluates the user's prompt with Claude Haiku before it reaches Claude.
# On a high-confidence match, injects a coaching note as additionalContext.
# Always exits 0 вЂ” never blocks a prompt.

set -euo pipefail

# Skip if this is an internal mentor call (prevents recursive evaluation)
[[ -n "${MENTOR_INTERNAL:-}" ]] && exit 0

COACHING_DIR="${HOME}/.claude/coaching"
CONFIG_FILE="${COACHING_DIR}/config.json"
PHILOSOPHY_FILE="${COACHING_DIR}/philosophy.md"
USER_MODEL_FILE="${COACHING_DIR}/user-model.json"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEFAULTS_DIR="$(cd "${SCRIPT_DIR}/../defaults" && pwd 2>/dev/null || echo "")"
EVALUATE_SCRIPT="${SCRIPT_DIR}/lib/evaluate-prompt.sh"

mkdir -p "$COACHING_DIR"
DBG() { echo "[$(date -Iseconds)] MENTOR-DBG $*" >> "${COACHING_DIR}/hook-debug.log" 2>/dev/null || true; }

# в”Ђв”Ђв”Ђ Reset trap: clear any persisted additionalContext when not coaching в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Without this, a coaching note injected on one prompt persists into all
# subsequent prompts because Claude Code keeps additionalContext in session context.
_EMIT_RESET=false
_COACHING_EMITTED=false
_EXIT_REASON="unknown"
_reset_context() {
    DBG "EXIT-TRAP: reason=${_EXIT_REASON} _EMIT_RESET=${_EMIT_RESET} _COACHING_EMITTED=${_COACHING_EMITTED}"
    if [[ "$_EMIT_RESET" == "true" ]] && [[ "$_COACHING_EMITTED" == "false" ]]; then
        local RESET_JSON='{"hookSpecificOutput":{"hookEventName":"UserPromptSubmit","additionalContext":""}}'
        DBG "EXIT-TRAP: emitting reset в†’ ${RESET_JSON}"
        printf '%s\n' "$RESET_JSON"
    fi
}
trap _reset_context EXIT

# в”Ђв”Ђв”Ђ Sweep orphaned session files (crashed sessions) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
find "$COACHING_DIR" -name 'session-*.tmp' -mtime +1 -delete 2>/dev/null || true

# в”Ђв”Ђв”Ђ Resolve jq (auto-installs on first use) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# shellcheck source=lib/bootstrap-jq.sh
source "${SCRIPT_DIR}/lib/bootstrap-jq.sh" || exit 0

# в”Ђв”Ђв”Ђ Read stdin в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
INPUT=$(cat)

PROMPT=$(     echo "$INPUT" | "$JQ" -r '.prompt     // ""' 2>/dev/null || echo "")
SESSION_ID=$( echo "$INPUT" | "$JQ" -r '.session_id // ""' 2>/dev/null || echo "")

[[ -z "$PROMPT" ]] && { _EXIT_REASON="empty-prompt"; exit 0; }
_EMIT_RESET=true   # real prompt вЂ” any non-coaching exit should now reset context
DBG "prompt='${PROMPT:0:80}' session='${SESSION_ID:-EMPTY}'"

# в”Ђв”Ђв”Ђ Load settings (defaults if config missing) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
ENABLED="true"
MODE="chill"
BOOTSTRAP_MIN=20
COOLDOWN_SECONDS=30
HISTORY_SIZE=10

if [[ -f "$CONFIG_FILE" ]]; then
    ENABLED=$(         "$JQ" -r 'if .enabled == false then "false" else "true" end' "$CONFIG_FILE" 2>/dev/null || echo "true")
    MODE=$(            "$JQ" -r '.mode               // "chill"' "$CONFIG_FILE" 2>/dev/null || echo "chill")
    BOOTSTRAP_MIN=$(   "$JQ" -r '.bootstrap_min      // 20'     "$CONFIG_FILE" 2>/dev/null || echo "20")
    COOLDOWN_SECONDS=$("$JQ" -r '.cooldown_seconds   // 30'     "$CONFIG_FILE" 2>/dev/null || echo "30")
    HISTORY_SIZE=$(    "$JQ" -r '.prompt_history_size // 10'     "$CONFIG_FILE" 2>/dev/null || echo "10")
fi

[[ "$ENABLED" != "true" ]] && { _EXIT_REASON="disabled"; exit 0; }

# в”Ђв”Ђв”Ђ Guard: skill invocations в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
echo "$PROMPT" | grep -qE "^/[a-z]" && { _EXIT_REASON="slash-command"; exit 0; }

# в”Ђв”Ђв”Ђ Guard: conversational affirmations в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
PROMPT_TRIMMED=$(echo "$PROMPT" | tr '[:upper:]' '[:lower:]' | tr -d '[:punct:]' | xargs)
AFFIRMATIONS="^(yes|no|ok|okay|sure|yep|nope|yup|nah|agreed|correct|exactly|right|proceed|continue|go ahead|do it|sounds good|looks good|make it so|that works|perfect|great|fine|done|got it)$"
echo "$PROMPT_TRIMMED" | grep -qiE "$AFFIRMATIONS" && { _EXIT_REASON="affirmation"; exit 0; }

# в”Ђв”Ђв”Ђ Guard: per-session cooldown в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
STATE_FILE="${COACHING_DIR}/session-${SESSION_ID}.tmp"
DBG "cooldown: session='${SESSION_ID:-EMPTY}' state_file=$([ -f "$STATE_FILE" ] && echo exists || echo missing) ls=$(ls -la "$STATE_FILE" 2>&1 || true)"
if [[ -n "$SESSION_ID" ]] && [[ -f "$STATE_FILE" ]]; then
    LAST_TS=$("$JQ" -r '.last_intervention_ts // 0' "$STATE_FILE" 2>/dev/null || echo "0")
    NOW_EPOCH=$(date +%s)
    ELAPSED=$(( NOW_EPOCH - LAST_TS ))
    if [[ "$ELAPSED" -lt "$COOLDOWN_SECONDS" ]]; then
        DBG "cooldown: BLOCKED elapsed=${ELAPSED}s < ${COOLDOWN_SECONDS}s"
        _EXIT_REASON="cooldown-blocked"
        exit 0
    fi
    DBG "cooldown: passed elapsed=${ELAPSED}s"
fi

# в”Ђв”Ђв”Ђ Guard: evaluate script must exist в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
[[ ! -f "$EVALUATE_SCRIPT" ]] && { _EXIT_REASON="no-evaluator"; exit 0; }

# в”Ђв”Ђв”Ђ Read prompt history from Claude Code history в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
HISTORY_FILE="${HOME}/.claude/history.jsonl"
HISTORY_JSON="[]"
if [[ -f "$HISTORY_FILE" ]] && [[ -n "$SESSION_ID" ]]; then
    HISTORY_LINES=$(tac "$HISTORY_FILE" \
        | "$JQ" --arg sid "$SESSION_ID" -r 'select(.sessionId == $sid) | .display' 2>/dev/null \
        | grep -v "^/" \
        | grep -vxF "$PROMPT" \
        | head -n "$HISTORY_SIZE" \
        | tac \
        | cut -c1-500) || true

    if [[ -n "$HISTORY_LINES" ]]; then
        HISTORY_JSON=$(printf '%s\n' "$HISTORY_LINES" | "$JQ" -R . | "$JQ" -s . 2>/dev/null || echo "[]")
    fi
fi

# в”Ђв”Ђв”Ђ Guard: short mid-conversation follow-ups в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# When the user is mid-conversation (prior prompts exist), short prompts
# are almost always answers to questions Claude asked. The evaluator can't
# see Claude's responses, so it can't verify вЂ” skip evaluation entirely.
TURN_COUNT=$(echo "$HISTORY_JSON" | "$JQ" 'length' 2>/dev/null || echo "0")
if [[ "$TURN_COUNT" -gt 0 ]]; then
    WORD_COUNT=$(echo "$PROMPT" | wc -w | tr -d ' ')
    if [[ "$WORD_COUNT" -le 4 ]]; then
        DBG "short-followup: skipping (${WORD_COUNT} words, turn $((TURN_COUNT + 1)))"
        _EXIT_REASON="short-followup"
        exit 0
    fi
    # Option-selection patterns: "approach A", "option 2", "the first one", etc.
    if echo "$PROMPT_TRIMMED" | grep -qiE "^(option|approach|choice|plan|alternative) [a-z0-9]$"; then
        DBG "option-selection: skipping mid-conversation option pick"
        _EXIT_REASON="option-selection"
        exit 0
    fi
    if echo "$PROMPT_TRIMMED" | grep -qiE "^the (first|second|third|last|other) (one|option|approach)$"; then
        DBG "option-selection: skipping mid-conversation selection"
        _EXIT_REASON="option-selection"
        exit 0
    fi
fi

# в”Ђв”Ђв”Ђ Bootstrap: seed defaults if missing в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
if [[ ! -f "$PHILOSOPHY_FILE" ]] && [[ -n "$DEFAULTS_DIR" ]] && [[ -f "${DEFAULTS_DIR}/philosophy.md" ]]; then
    cp "${DEFAULTS_DIR}/philosophy.md" "$PHILOSOPHY_FILE" 2>/dev/null || true
fi

if [[ ! -f "$USER_MODEL_FILE" ]]; then
    printf '{"strengths":[],"weaknesses":[],"current_focus":"","recent_progress":"","intervention_history":[]}\n' \
        > "$USER_MODEL_FILE" 2>/dev/null || true
fi

# в”Ђв”Ђв”Ђ Load philosophy and user model в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
PHILOSOPHY=""
[[ -f "$PHILOSOPHY_FILE" ]] && PHILOSOPHY=$(cat "$PHILOSOPHY_FILE" 2>/dev/null || echo "")

USER_MODEL="{}"
[[ -f "$USER_MODEL_FILE" ]] && USER_MODEL=$(cat "$USER_MODEL_FILE" 2>/dev/null || echo "{}")

# в”Ђв”Ђв”Ђ Build payload and call evaluate-prompt.sh в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
PAYLOAD=$("$JQ" -n \
    --arg     prompt     "$PROMPT" \
    --arg     mode       "$MODE" \
    --arg     philosophy "$PHILOSOPHY" \
    --argjson user_model "$USER_MODEL" \
    --argjson history    "$HISTORY_JSON" \
    '{prompt: $prompt, mode: $mode, philosophy: $philosophy, user_model: $user_model, history: $history}' \
    2>/dev/null) || exit 0

JUDGMENT=$(printf '%s' "$PAYLOAD" | timeout 28 bash "$EVALUATE_SCRIPT" 2>/dev/null \
    || echo '{"intervene":false}')
DBG "judgment: $(printf '%s' "$JUDGMENT" | tr -d '\n')"

# в”Ђв”Ђв”Ђ Parse judgment в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
INTERVENE=$(        echo "$JUDGMENT" | "$JQ" -r '.intervene // false' 2>/dev/null || echo "false")
[[ "$INTERVENE" != "true" ]] && { _EXIT_REASON="no-intervention"; exit 0; }

INTERVENTION_TYPE=$(echo "$JUDGMENT" | "$JQ" -r '.type    // "nudge"' 2>/dev/null || echo "nudge")
FEEDBACK=$(         echo "$JUDGMENT" | "$JQ" -r '.message // ""'      2>/dev/null || echo "")
[[ -z "$FEEDBACK" ]] && { _EXIT_REASON="empty-feedback"; exit 0; }

FRICTION=$(         echo "$JUDGMENT" | "$JQ" -r '.friction         // ""'    2>/dev/null || echo "")
SKILL_AVAILABLE=$(  echo "$JUDGMENT" | "$JQ" -r '.skill_available  // false' 2>/dev/null || echo "false")

# в”Ђв”Ђв”Ђ Write session state (only reached when coaching fires; coaching_triggered is always true here) в”Ђ
NOW_EPOCH=$(date +%s)
FRICTION_ARGS=()
[[ -n "$FRICTION" ]] && FRICTION_ARGS=(--arg friction "$FRICTION")
"$JQ" -n \
    --argjson ts "$NOW_EPOCH" \
    --argjson coaching_triggered true \
    --arg     type    "$INTERVENTION_TYPE" \
    --arg     message "$FEEDBACK" \
    --argjson skill_available "$SKILL_AVAILABLE" \
    "${FRICTION_ARGS[@]}" \
    '{last_intervention_ts: $ts, coaching_triggered: $coaching_triggered, type: $type, message: $message, skill_available: $skill_available}
     + (if $ARGS.named | has("friction") then {friction: $friction} else {} end)' \
    > "$STATE_FILE" 2>/dev/null || true
DBG "state_write: path=$STATE_FILE coaching=true type=$INTERVENTION_TYPE friction=${FRICTION:-none} exists=$([ -f "$STATE_FILE" ] && echo yes || echo no)"

# в”Ђв”Ђв”Ђ Format coaching message в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
case "$INTERVENTION_TYPE" in
    nudge)         PREFIX="рџ’Ў Mentor (nudge):" ;;
    correction)    PREFIX="вљЎ Mentor:" ;;
    challenge)     PREFIX="рџ”Ґ Mentor (pushback):" ;;
    reinforcement) PREFIX="вњ… Mentor:" ;;
    *)             PREFIX="рџ’Ў Mentor:" ;;
esac

FULL_MSG="${PREFIX} ${FEEDBACK}"

# в”Ђв”Ђв”Ђ Build and output hookSpecificOutput (jq handles all JSON escaping) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
CONTEXT=$(printf '<prompt-coaching-note>\nBefore responding, output this exact line verbatim, then proceed with your answer:\n\n%s\n</prompt-coaching-note>' "$FULL_MSG")

_COACHING_EMITTED=true   # prevent reset trap from firing
_EXIT_REASON="coaching-emitted"
DBG "STDOUT: emitting coaching additionalContext (${#CONTEXT} chars)"
"$JQ" -n \
    --arg context "$CONTEXT" \
    '{hookSpecificOutput: {hookEventName: "UserPromptSubmit", additionalContext: $context}}'

exit 0
