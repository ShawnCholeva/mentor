{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PLUGIN_ROOT}/plugins/mentor/hooks/run-hook.ps1\" user-prompt-submit",
            "async": false,
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PLUGIN_ROOT}/plugins/mentor/hooks/run-hook.ps1\" stop-logger",
            "async": true
          }
        ]
      }
    ]
  }
}
