{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/plugins/mentor/hooks/run-hook.cmd\" user-prompt-submit",
            "async": false,
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/plugins/mentor/hooks/run-hook.cmd\" stop-logger",
            "async": true
          }
        ]
      }
    ]
  }
}
