#!/usr/bin/env bash
# UserPromptSubmit hook — AI-powered prompt coaching via additionalContext
# Part of mentor plugin (v3.1)
#
# Evaluates the user's prompt with Claude Haiku before it reaches Claude.
# On a high-confidence match, injects a coaching note as additionalContext.
# Always exits 0 — never blocks a prompt.

set -euo pipefail

# Skip if this is an internal mentor call (prevents recursive evaluation)
[[ -n "${MENTOR_INTERNAL:-}" ]] && exit 0

COACHING_DIR="${HOME}/.claude/coaching"
CONFIG_FILE="${COACHING_DIR}/config.json"
PHILOSOPHY_FILE="${COACHING_DIR}/philosophy.md"
USER_MODEL_FILE="${COACHING_DIR}/user-model.json"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEFAULTS_DIR="$(cd "${SCRIPT_DIR}/../defaults" && pwd 2>/dev/null || echo "")"
EVALUATE_SCRIPT="${SCRIPT_DIR}/lib/evaluate-prompt.sh"

mkdir -p "$COACHING_DIR"

# ─── Resolve jq (auto-installs on first use) ──────────────────────────────────
# shellcheck source=lib/bootstrap-jq.sh
source "${SCRIPT_DIR}/lib/bootstrap-jq.sh" || exit 0

# ─── Read stdin ───────────────────────────────────────────────────────────────
INPUT=$(cat)

PROMPT=$(     echo "$INPUT" | "$JQ" -r '.prompt     // ""' 2>/dev/null || echo "")
SESSION_ID=$( echo "$INPUT" | "$JQ" -r '.session_id // ""' 2>/dev/null || echo "")

[[ -z "$PROMPT" ]] && exit 0

# ─── Load settings (defaults if config missing) ───────────────────────────────
ENABLED="true"
MODE="chill"
BOOTSTRAP_MIN=20

if [[ -f "$CONFIG_FILE" ]]; then
    ENABLED=$(     "$JQ" -r 'if .enabled == false then "false" else "true" end' "$CONFIG_FILE" 2>/dev/null || echo "true")
    MODE=$(        "$JQ" -r '.mode          // "chill"' "$CONFIG_FILE" 2>/dev/null || echo "chill")
    BOOTSTRAP_MIN=$("$JQ" -r '.bootstrap_min // 20'    "$CONFIG_FILE" 2>/dev/null || echo "20")
fi

[[ "$ENABLED" != "true" ]] && exit 0

# ─── Guard: skill invocations ─────────────────────────────────────────────────
echo "$PROMPT" | grep -qE "^/[a-z]" && exit 0

# ─── Guard: conversational affirmations ───────────────────────────────────────
PROMPT_TRIMMED=$(echo "$PROMPT" | tr '[:upper:]' '[:lower:]' | tr -d '[:punct:]' | xargs)
AFFIRMATIONS="^(yes|no|ok|okay|sure|yep|nope|yup|nah|agreed|correct|exactly|right|proceed|continue|go ahead|do it|sounds good|looks good|make it so|that works|perfect|great|fine|done|got it)$"
echo "$PROMPT_TRIMMED" | grep -qiE "$AFFIRMATIONS" && exit 0

# ─── Guard: per-session cooldown (30s) ────────────────────────────────────────
STATE_FILE="${COACHING_DIR}/session-${SESSION_ID}.tmp"
if [[ -n "$SESSION_ID" ]] && [[ -f "$STATE_FILE" ]]; then
    LAST_TS=$("$JQ" -r '.timestamp // 0' "$STATE_FILE" 2>/dev/null || echo "0")
    NOW_EPOCH=$(date +%s)
    ELAPSED=$(( NOW_EPOCH - LAST_TS ))
    [[ "$ELAPSED" -lt 30 ]] && exit 0
fi

# ─── Guard: evaluate script must exist ───────────────────────────────────────
[[ ! -f "$EVALUATE_SCRIPT" ]] && exit 0

# ─── Bootstrap: seed defaults if missing ─────────────────────────────────────
if [[ ! -f "$PHILOSOPHY_FILE" ]] && [[ -n "$DEFAULTS_DIR" ]] && [[ -f "${DEFAULTS_DIR}/philosophy.md" ]]; then
    cp "${DEFAULTS_DIR}/philosophy.md" "$PHILOSOPHY_FILE" 2>/dev/null || true
fi

if [[ ! -f "$USER_MODEL_FILE" ]]; then
    printf '{"strengths":[],"weaknesses":[],"current_focus":"","recent_progress":"","intervention_history":[]}\n' \
        > "$USER_MODEL_FILE" 2>/dev/null || true
fi

# ─── Load philosophy and user model ──────────────────────────────────────────
PHILOSOPHY=""
[[ -f "$PHILOSOPHY_FILE" ]] && PHILOSOPHY=$(cat "$PHILOSOPHY_FILE" 2>/dev/null || echo "")

USER_MODEL="{}"
[[ -f "$USER_MODEL_FILE" ]] && USER_MODEL=$(cat "$USER_MODEL_FILE" 2>/dev/null || echo "{}")

# ─── Build payload and call evaluate-prompt.sh ───────────────────────────────
PAYLOAD=$("$JQ" -n \
    --arg     prompt     "$PROMPT" \
    --arg     mode       "$MODE" \
    --arg     philosophy "$PHILOSOPHY" \
    --argjson user_model "$USER_MODEL" \
    '{prompt: $prompt, mode: $mode, philosophy: $philosophy, user_model: $user_model}' \
    2>/dev/null) || exit 0

JUDGMENT=$(printf '%s' "$PAYLOAD" | timeout 12 bash "$EVALUATE_SCRIPT" 2>/dev/null \
    || echo '{"intervene":false}')

# ─── Parse judgment ───────────────────────────────────────────────────────────
INTERVENE=$(        echo "$JUDGMENT" | "$JQ" -r '.intervene // false' 2>/dev/null || echo "false")
[[ "$INTERVENE" != "true" ]] && exit 0

INTERVENTION_TYPE=$(echo "$JUDGMENT" | "$JQ" -r '.type    // "nudge"' 2>/dev/null || echo "nudge")
FEEDBACK=$(         echo "$JUDGMENT" | "$JQ" -r '.message // ""'      2>/dev/null || echo "")
[[ -z "$FEEDBACK" ]] && exit 0

# ─── Write session state (epoch timestamp) ────────────────────────────────────
NOW_EPOCH=$(date +%s)
"$JQ" -n \
    --arg     type      "$INTERVENTION_TYPE" \
    --arg     message   "$FEEDBACK" \
    --argjson timestamp "$NOW_EPOCH" \
    '{coaching_triggered: true, type: $type, tags: [$type], message: $message, timestamp: $timestamp}' \
    > "$STATE_FILE" 2>/dev/null || true

# ─── Format coaching message ──────────────────────────────────────────────────
case "$INTERVENTION_TYPE" in
    nudge)         PREFIX="💡 Mentor (nudge):" ;;
    correction)    PREFIX="⚡ Mentor:" ;;
    challenge)     PREFIX="🔥 Mentor (pushback):" ;;
    reinforcement) PREFIX="✅ Mentor:" ;;
    *)             PREFIX="💡 Mentor:" ;;
esac

FULL_MSG="${PREFIX} ${FEEDBACK}"

# ─── Build and output hookSpecificOutput (jq handles all JSON escaping) ───────
CONTEXT=$(printf '<prompt-coaching-note>\nBefore responding, output this exact line verbatim, then proceed with your answer:\n\n%s\n</prompt-coaching-note>' "$FULL_MSG")

"$JQ" -n \
    --arg context "$CONTEXT" \
    '{hookSpecificOutput: {hookEventName: "UserPromptSubmit", additionalContext: $context}}'

exit 0
