#!/usr/bin/env bash
# UserPromptSubmit hook — AI-powered prompt coaching via additionalContext
# Part of mentor plugin (v2.0)
#
# Evaluates the user's prompt with Claude haiku before it reaches Claude.
# On a high-confidence match, injects a coaching note as additionalContext
# so Claude surfaces it at the top of its response.
# Always exits 0 — never blocks a prompt (NFR-5).

set -euo pipefail

COACHING_DIR="${HOME}/.claude/coaching"
CONFIG_FILE="${COACHING_DIR}/config.json"
LOG_FILE="${COACHING_DIR}/interactions.jsonl"
PHILOSOPHY_FILE="${COACHING_DIR}/philosophy.md"
USER_MODEL_FILE="${COACHING_DIR}/user-model.json"

# Resolve script directory to find lib/ scripts
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEFAULTS_DIR="$(cd "$SCRIPT_DIR/../defaults" && pwd 2>/dev/null || echo "")"
EVALUATE_SCRIPT="${SCRIPT_DIR}/lib/evaluate-prompt.py"

mkdir -p "$COACHING_DIR"

# ─── JSON parsing: python3 → python → silent pass-through ────────────────────
PYTHON_CMD=""
if command -v python3 &>/dev/null; then
    PYTHON_CMD="python3"
elif command -v python &>/dev/null; then
    PYTHON_CMD="python"
else
    exit 0
fi

# ─── Read stdin ───────────────────────────────────────────────────────────────
INPUT=$(cat)

get_field() {
    local field="$1"
    printf '%s' "$INPUT" | "$PYTHON_CMD" -c "
import json, sys
try:
    d = json.load(sys.stdin)
    v = d.get('$field', '')
    print(v if isinstance(v, str) else '')
except:
    print('')
" 2>/dev/null || echo ""
}

PROMPT=$(get_field "prompt")
SESSION_ID=$(get_field "session_id")

[[ -z "$PROMPT" ]] && exit 0

# ─── Load settings (defaults if config missing) ───────────────────────────────
ENABLED="true"
MODE="chill"
BOOTSTRAP_MIN=20

if [[ -f "$CONFIG_FILE" ]]; then
    _parse_config() {
        printf '%s' "$(cat "$CONFIG_FILE")" | "$PYTHON_CMD" -c "
import json, sys
try:
    d = json.load(sys.stdin)
    print(str(d.get('enabled', True)).lower())
    print(d.get('mode', 'chill'))
    print(d.get('bootstrap_min', 20))
except:
    print('true'); print('chill'); print(20)
" 2>/dev/null || printf "true\nchill\n20\n"
    }
    IFS=$'\n' read -r ENABLED MODE BOOTSTRAP_MIN <<< "$(_parse_config)"
fi

[[ "$ENABLED" != "true" ]] && exit 0

# ─── Guard: skill invocations — never coach on /command prompts ───────────────
if echo "$PROMPT" | grep -qE "^/[a-z]"; then
    exit 0
fi

# ─── Guard: conversational affirmations ───────────────────────────────────────
PROMPT_TRIMMED=$(echo "$PROMPT" | tr '[:upper:]' '[:lower:]' | tr -d '[:punct:]' | xargs)
AFFIRMATIONS="^(yes|no|ok|okay|sure|yep|nope|yup|nah|agreed|correct|exactly|right|proceed|continue|go ahead|do it|sounds good|looks good|make it so|that works|perfect|great|fine|done|got it)$"
if echo "$PROMPT_TRIMMED" | grep -qiE "$AFFIRMATIONS"; then
    exit 0
fi

# ─── Guard: per-session cooldown (30s) ────────────────────────────────────────
STATE_FILE_EARLY="${COACHING_DIR}/session-${SESSION_ID}.tmp"
if [[ -f "$STATE_FILE_EARLY" ]]; then
    LAST_TS=$(printf '%s' "$(cat "$STATE_FILE_EARLY")" | "$PYTHON_CMD" -c "
import json, sys, datetime
try:
    d = json.load(sys.stdin)
    ts = d.get('timestamp', '')
    if ts:
        last = datetime.datetime.fromisoformat(ts.replace('Z', '+00:00'))
        now = datetime.datetime.now(datetime.timezone.utc)
        print(int((now - last).total_seconds()))
    else:
        print(9999)
except:
    print(9999)
" 2>/dev/null || echo "9999")
    if [[ "$LAST_TS" -lt 30 ]]; then
        exit 0
    fi
fi

# ─── Guard: API key required ──────────────────────────────────────────────────
# Use MENTOR_API_KEY to avoid conflicting with Claude Code's own auth detection.
MENTOR_API_KEY="${MENTOR_API_KEY:-}"
[[ -z "$MENTOR_API_KEY" ]] && exit 0

# ─── Guard: evaluate script must exist ────────────────────────────────────────
[[ ! -f "$EVALUATE_SCRIPT" ]] && exit 0

# ─── Bootstrap: seed philosophy.md if missing ────────────────────────────────
if [[ ! -f "$PHILOSOPHY_FILE" ]] && [[ -n "$DEFAULTS_DIR" ]] && [[ -f "${DEFAULTS_DIR}/philosophy.md" ]]; then
    cp "${DEFAULTS_DIR}/philosophy.md" "$PHILOSOPHY_FILE" 2>/dev/null || true
fi

# ─── Bootstrap: seed user-model.json if missing ──────────────────────────────
if [[ ! -f "$USER_MODEL_FILE" ]]; then
    printf '{"strengths":[],"weaknesses":[],"current_focus":"","recent_progress":"","intervention_history":[]}\n' > "$USER_MODEL_FILE" 2>/dev/null || true
fi

# ─── Load philosophy and user model ──────────────────────────────────────────
PHILOSOPHY=""
if [[ -f "$PHILOSOPHY_FILE" ]]; then
    PHILOSOPHY=$(cat "$PHILOSOPHY_FILE" 2>/dev/null || echo "")
fi

USER_MODEL="{}"
if [[ -f "$USER_MODEL_FILE" ]]; then
    USER_MODEL=$(cat "$USER_MODEL_FILE" 2>/dev/null || echo "{}")
fi

# ─── Build JSON payload for evaluate-prompt.py ───────────────────────────────
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

PROMPT_ESC=$(escape_for_json "$PROMPT")
PHILOSOPHY_ESC=$(escape_for_json "$PHILOSOPHY")

MENTOR_API_KEY_ESC=$(escape_for_json "$MENTOR_API_KEY")
PAYLOAD=$(printf '{"prompt":"%s","mode":"%s","philosophy":"%s","user_model":%s,"api_key":"%s"}' \
    "$PROMPT_ESC" \
    "$MODE" \
    "$PHILOSOPHY_ESC" \
    "$USER_MODEL" \
    "$MENTOR_API_KEY_ESC")

# ─── Call evaluate-prompt.py (6s timeout) ─────────────────────────────────────
JUDGMENT=$(printf '%s' "$PAYLOAD" | timeout 6 "$PYTHON_CMD" "$EVALUATE_SCRIPT" 2>/dev/null || echo '{"intervene":false}')

# ─── Parse judgment ────────────────────────────────────────────────────────────
INTERVENE=$( printf '%s' "$JUDGMENT" | "$PYTHON_CMD" -c "
import json, sys
try:
    d = json.load(sys.stdin)
    print('true' if d.get('intervene') else 'false')
except:
    print('false')
" 2>/dev/null || echo "false")

[[ "$INTERVENE" != "true" ]] && exit 0

INTERVENTION_TYPE=$(printf '%s' "$JUDGMENT" | "$PYTHON_CMD" -c "
import json, sys
try:
    d = json.load(sys.stdin)
    print(d.get('type', 'nudge'))
except:
    print('nudge')
" 2>/dev/null || echo "nudge")

FEEDBACK=$(printf '%s' "$JUDGMENT" | "$PYTHON_CMD" -c "
import json, sys
try:
    d = json.load(sys.stdin)
    print(d.get('message', ''))
except:
    print('')
" 2>/dev/null || echo "")

[[ -z "$FEEDBACK" ]] && exit 0

# ─── Write session state for stop-logger ─────────────────────────────────────
TIMESTAMP=$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo "")
STATE_FILE="${COACHING_DIR}/session-${SESSION_ID}.tmp"
FEEDBACK_FOR_STATE=$(escape_for_json "$FEEDBACK")
printf '{"coaching_triggered":true,"type":"%s","tags":["%s"],"message":"%s","timestamp":"%s"}\n' \
    "$INTERVENTION_TYPE" \
    "$INTERVENTION_TYPE" \
    "$FEEDBACK_FOR_STATE" \
    "$TIMESTAMP" > "$STATE_FILE"

# ─── Format coaching message by intervention type ─────────────────────────────
case "$INTERVENTION_TYPE" in
    nudge)         PREFIX="💡 Mentor (nudge):" ;;
    correction)    PREFIX="⚡ Mentor:" ;;
    challenge)     PREFIX="🔥 Mentor (pushback):" ;;
    reinforcement) PREFIX="✅ Mentor:" ;;
    *)             PREFIX="💡 Mentor:" ;;
esac

FULL_MSG="${PREFIX} ${FEEDBACK}"

# ─── Build coaching message ───────────────────────────────────────────────────
FULL_MSG_ESC=$(escape_for_json "$FULL_MSG")
COACHING_MSG="<prompt-coaching-note>\\nBefore responding, output this exact line verbatim, then proceed with your answer:\\n\\n${FULL_MSG_ESC}\\n</prompt-coaching-note>"

# ─── Output hookSpecificOutput ────────────────────────────────────────────────
printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "UserPromptSubmit",\n    "additionalContext": "%s"\n  }\n}\n' "$COACHING_MSG"

exit 0
